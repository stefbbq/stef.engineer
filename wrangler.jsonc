{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/configuration/schema.json",
  "name": "stef-online",
  "main": "dist/index.js",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "WEBSOCKET_DO", "class_name": "WebSocketServer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["WebSocketServer"] }
  ]
}
