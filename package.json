{
  "name": "stef-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && wrangler dev --remote",
    "build": "pnpm build:client && pnpm embed:client && pnpm build:ssr",
    "build:client": "vite build --config vite.client.config.ts",
    "embed:client": "node scripts/embed-client.mjs",
    "build:ssr": "vite build --ssr src/index.tsx --config vite.entry.config.ts",
    "deploy": "pnpm build && wrangler deploy",
    "seed": "tsx scripts/seed-kv.ts",
    "seed:art": "tsx scripts/seed-art.ts"
  },
  "dependencies": {
    "@touchlesscode/core": "latest",
    "@touchlesscode/core-extensions": "^1.1.13",
    "@touchlesscode/core-vite": "latest",
    "@touchlesscode/log": "^1.1.6",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "firebase": "^9.22.0",
    "image-size": "^2.0.2",
    "sass": "^1.69.2",
    "tsx": "latest",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.11.12",
    "wrangler": "^4.84.1"
  }
}
